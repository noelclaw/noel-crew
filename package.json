{
  "name": "@noelclaw/crew",
  "version": "2.0.7",
  "private": true,
  "description": "Noel Crew — tray-first desktop companion for AI coding agents",
  "author": "noelclaw",
  "license": "MIT",
  "repository": "https://github.com/noelclaw/noel-crew",
  "homepage": "https://noelclaw.fun",
  "type": "module",
  "packageManager": "pnpm@11.0.8",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:desktop": "pnpm --filter @noelclaw/desktop dev",
    "package:desktop:dir": "pnpm build && pnpm --filter @noelclaw/desktop package:dir",
    "package:desktop": "pnpm build && pnpm --filter @noelclaw/desktop package",
    "release:desktop": "node apps/desktop/scripts/release-local.mjs",
    "release:npm": "node scripts/release-npm.mjs",
    "test": "pnpm build && pnpm -r --if-present test",
    "check": "pnpm -r check",
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm -r build"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@google/genai", "koffi", "protobufjs"]
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
