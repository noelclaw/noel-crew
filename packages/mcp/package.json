{
  "name": "@noelclaw/crew",
  "version": "0.1.3",
  "description": "Noel Crew — tray-first desktop companion MCP for AI coding agents",
  "license": "MIT",
  "homepage": "https://noelclaw.fun",
  "keywords": [
    "mcp",
    "noelclaw",
    "desktop-pet",
    "ai-agent",
    "claude-code"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/noelclaw/noel-crew.git",
    "directory": "packages/mcp"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "noelclaw-crew": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "test": "node dist/check-mcp-contract.js",
    "check": "pnpm --filter @noelclaw/client build && pnpm typecheck && pnpm build && pnpm test",
    "typecheck": "tsc --noEmit",
    "build": "tsc && node dist/ensure-executable.js"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@noelclaw/client": "workspace:*",
    "zod": "^4.4.3"
  }
}
