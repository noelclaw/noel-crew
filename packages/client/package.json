{
  "name": "@noelclaw/client",
  "version": "2.0.6",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/noelclaw/noel-crew.git",
    "directory": "packages/client"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
