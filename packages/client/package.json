    "smoke": "pnpm build && node dist/smoke.js",
    "smoke:status": "pnpm smoke status",
    "smoke:react": "pnpm smoke react",
    "smoke:say": "pnpm smoke say",
    "smoke:invalid-token": "pnpm smoke invalid-token"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "typescript": "^6.0.3"
  }
